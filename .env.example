# Turso (libsql)
TURSO_DATABASE_URL=libsql://your-db-name-yourusername.turso.io
TURSO_AUTH_TOKEN=

# Admin auth
ADMIN_PASSWORD=change-me-now
# 32+ random bytes, base64. Generate locally: `openssl rand -base64 32`
SESSION_SECRET=

# Resend (transactional email)
RESEND_API_KEY=
# The verified sending domain on Resend. Example: "Socceroos Watch Parties <hello@your-domain.com>"
RESEND_FROM=

# Vercel Blob (venue logos)
BLOB_READ_WRITE_TOKEN=

# Mapbox forward geocoding (for admin venue addresses → lat/lng).
# Same `pk.…` token can be used for both; the public one is what the
# browser map uses.
MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=

# Public site URL (used in emails). No trailing slash. Example: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cron secret — set as `CRON_SECRET` on Vercel. The reminder route verifies this header.
CRON_SECRET=
